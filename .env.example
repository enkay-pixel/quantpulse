# Copy to .env and adjust. Everything runs locally; these are not real-world secrets,
# but keep .env out of git anyway (already ignored).

# --- Postgres ---
POSTGRES_USER=quantpulse
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=market
POSTGRES_PORT=5432

# Connection string used by the app (host-side; containers override the host)
DATABASE_URL=postgresql+psycopg://quantpulse:change-me-locally@localhost:5432/market

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Pipeline behavior ---
QUANTPULSE_UNIVERSE_FILE=configs/universe.yaml
QUANTPULSE_HISTORY_START=2018-01-01
